# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-only. Never expose to the client.

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=                  # Server-only. Never expose to the client.

# ── Mailgun ───────────────────────────────────────────────────────────────────
# https://app.mailgun.com/
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=Extension Pulse <noreply@mg.yourdomain.com>

# ── App ───────────────────────────────────────────────────────────────────────
# The public URL of this deployment (no trailing slash).
# Used for auth redirects and email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Docs integration (optional) ────────────────────────────────────────
# Enables importing content from Google Docs into Pulse field notes.
# Create a service account in Google Cloud Console with Drive read access.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
